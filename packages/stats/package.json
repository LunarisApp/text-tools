{
  "name": "@lunarisapp/stats",
  "description": "A library for calculating text statistics (e.g. word count)",
  "version": "2.0.0",
  "author": {
    "name": "Roman Sirokov",
    "url": "https://mrlightful.com",
    "email": "roman@lunaris.app"
  },
  "homepage": "https://lunaris.app",
  "repository": {
    "url": "https://github.com/LunarisApp/text-tools"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "keywords": [
    "statistics",
    "metrics",
    "text",
    "linguistics",
    "language",
    "word count",
    "sentence count",
    "syllable count",
    "reading time"
  ],
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./syllables": {
      "types": "./dist/syllables.d.ts",
      "import": "./dist/syllables.mjs",
      "require": "./dist/syllables.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "jest"
  },
  "dependencies": {
    "@lunarisapp/cmudict": "workspace:*",
    "@lunarisapp/hyphen": "workspace:*",
    "@lunarisapp/language": "workspace:*",
    "lru-cache": "^11.5.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@jest/globals": "^30.4.1",
    "babel-jest": "^30.4.1",
    "jest": "^30.4.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
